{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "clientCode": {
      "type": "string"
    },
    "author": {
      "type": "string"
    },
    "companyName": {
      "type": "string"
    },
    "contactEmail": {
      "type": "string"
    },
    "rating": {
      "type": "number",
      "minimum": 1,
      "maximum": 5
    },
    "approved": {
      "default": false,
      "type": "boolean"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "clientCode",
    "author",
    "companyName",
    "contactEmail",
    "rating"
  ]
}