---
interface Props {
  title: string;
  description: string;
  heading: string;
  currentPage: 'ochrana' | 'cookies' | 'obchodne';
}

const { title, description, heading, currentPage } = Astro.props;

import BaseLayout from './BaseLayout.astro';
import '../styles/legal.css';
---

<BaseLayout {title} {description}>

  <header class="site-header">
    <nav class="container nav" aria-label="Hlavná navigácia">
      <a class="logo" href="/" aria-label="Esticode domovská stránka">
        <img src="/img/Logo_White.svg" alt="Esticode">
      </a>
    </nav>
  </header>

  <main>
    <section class="section">
      <div class="container legal-shell">
        <article class="legal-content fade-in is-visible">
          <p class="kicker">Právne informácie</p>
          <h1>{heading}</h1>
          <slot />
        </article>

        <aside class="legal-side fade-in is-visible" aria-label="Navigácia právnych stránok">
          <p class="kicker">Navigácia</p>
          <h2>Právne stránky</h2>
          <nav>
            <a href="/ochrana-osobnych-udajov" aria-current={currentPage === 'ochrana' ? 'page' : undefined}>
              Ochrana osobných údajov
            </a>
            <a href="/cookies" aria-current={currentPage === 'cookies' ? 'page' : undefined}>
              Cookies
            </a>
            <a href="/obchodne-podmienky" aria-current={currentPage === 'obchodne' ? 'page' : undefined}>
              Obchodné podmienky
            </a>
          </nav>
          <a class="legal-back" href="/">Späť na hlavnú stránku</a>
        </aside>
      </div>
    </section>
  </main>

  <script>
    import '../scripts/main.js';
  </script>
</BaseLayout>
