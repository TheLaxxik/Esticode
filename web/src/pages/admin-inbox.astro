---
// src/pages/admin-inbox.astro

import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';

type SubmissionData = Record<string, string | undefined>;

interface SubmissionItem {
  created_at: string;
  data: SubmissionData;
}

// Bezpečné načítanie premenných pre localhost (Vite) aj pre produkciu Netlify
const accessToken = import.meta.env.NETLIFY_ACCESS_TOKEN || process.env.NETLIFY_ACCESS_TOKEN;
const siteId = import.meta.env.NETLIFY_SITE_ID || process.env.NETLIFY_SITE_ID;

let submissions: SubmissionItem[] = [];
let error: string | null = null;

// Kontrola kľúčov pred spustením API požiadavky
if (!accessToken || !siteId) {
  error = "Chýbajú prístupové kľúče. Skontrolujte, či máte premenné správne uložené v Netlify alebo v lokálnom súbore .env.";
} else {
  try {
    const response = await fetch(
      `https://api.netlify.com/api/v1/sites/${siteId}/submissions`,
      {
        headers: {
          Authorization: `Bearer ${accessToken}`,
          'Content-Type': 'application/json'
        },
      }
    );

    if (!response.ok) {
      throw new Error(`Netlify API vrátilo chybový status ${response.status}`);
    }

    submissions = (await response.json()) as SubmissionItem[];
  } catch (e) {
    error = e instanceof Error ? e.message : 'Nepodarilo sa načítať dáta z Netlify API.';
  }
}

// Pomocná funkcia na pekné formátovanie slovenského dátumu a času
const formatDate = (dateString: string) => {
  return new Date(dateString).toLocaleDateString('sk-SK', {
    day: '2-digit',
    month: '2-digit',
    year: 'numeric',
    hour: '2-digit',
    minute: '2-digit',
  });
};
---

<BaseLayout
  title="Esticode | Admin Inbox"
  description="Admin prehľad prijatých dopytov z webového formulára."
  robots="noindex,nofollow"
>
  <main>
    <section class="section admin-inbox-section" id="admin-inbox">
      <div class="container">
        <header class="section-header admin-inbox-header">
          <p class="kicker">Admin</p>
          <h1>Inbox dopytov</h1>
          <p class="section-note">Prehľad prijatých zákaziek z dopytového formulára.</p>
          <p class="admin-inbox-count">Spolu: {submissions.length}</p>
        </header>

        {error && (
          <div class="admin-system-error" role="alert">
            <strong>Status systému:</strong> {error}
          </div>
        )}

        {!error && submissions.length === 0 && (
          <div class="admin-empty-state">
            <p>Zatiaľ neprišli žiadne dopyty. Schránka je prázdna.</p>
          </div>
        )}

        <div class="admin-inbox-list">
          {submissions.map((sub) => (
            <article class="admin-inbox-card">
              <div class="admin-inbox-top">
                <div>
                  <h2>
                    {sub.data.meno || 'Neznáme meno'}
                    {sub.data.firma_znacka || sub.data['firma/znacka'] ? (
                      <span class="admin-company-badge">
                        {sub.data.firma_znacka || sub.data['firma/znacka']}
                      </span>
                    ) : null}
                  </h2>
                  <a href={`mailto:${sub.data.email}`} class="admin-email-link">
                    {sub.data.email || 'Bez emailu'}
                  </a>
                </div>
                <p class="admin-date-badge">{formatDate(sub.created_at)}</p>
              </div>

              <div class="admin-inbox-meta">
                <div>
                  <p class="admin-meta-label">Rozpočet</p>
                  <p class="admin-meta-value">{sub.data.rozpocet || 'Neuvedený'}</p>
                </div>
                <div>
                  <p class="admin-meta-label">Spustenie webu</p>
                  <p class="admin-meta-value">
                    {sub.data.termin_spustenia || sub.data['kedy-chcete-spustit-web'] || sub.data.termin || 'Neuvedený'}
                  </p>
                </div>
              </div>

              <div>
                <p class="admin-meta-label">Viac detailov o projekte</p>
                <p class="admin-message-box">
                  {sub.data.sprava || sub.data.message || 'Klient neodoslal žiadny sprievodný text.'}
                </p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .admin-inbox-section {
    min-block-size: 100vh;
    padding-block-start: var(--space-7);
  }

  .admin-inbox-header {
    margin-block-end: var(--space-5);
  }

  .admin-inbox-header h1 {
    font-size: clamp(1.75rem, 5vw, 2.6rem);
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .admin-inbox-count {
    margin-block-start: var(--space-3);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.28rem 0.72rem;
    border: 1px solid var(--color-line);
    border-radius: 999px;
    font-size: 0.78rem;
    color: var(--color-muted);
  }

  .admin-system-error {
    margin-block-end: var(--space-5);
    border: 1px solid #7a2d2d;
    border-radius: 12px;
    background: rgba(79, 20, 20, 0.38);
    color: #fecaca;
    padding: 0.9rem 1rem;
  }

  .admin-system-error strong {
    color: #fca5a5;
  }

  .admin-empty-state {
    border: 1px dashed var(--color-line);
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.01);
    text-align: center;
    padding: var(--space-7) var(--space-4);
    color: var(--color-muted);
  }

  .admin-inbox-list {
    display: grid;
    gap: var(--space-5);
  }

  .admin-inbox-card {
    border: 1px solid var(--color-line);
    border-radius: 16px;
    padding: var(--space-5);
    background:
      linear-gradient(155deg, rgba(137, 196, 255, 0.08) 0%, rgba(255, 255, 255, 0) 48%),
      rgba(255, 255, 255, 0.02);
    transition: transform var(--transition-fast), border-color var(--transition-fast), box-shadow var(--transition-fast);
    display: grid;
    gap: var(--space-4);
  }

  .admin-inbox-card:hover {
    transform: translateY(-4px);
    border-color: #5b6f82;
    box-shadow: 0 14px 28px rgba(0, 0, 0, 0.2);
  }

  .admin-inbox-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-3);
    border-block-end: 1px solid rgba(255, 255, 255, 0.08);
    padding-block-end: var(--space-3);
  }

  .admin-inbox-top h2 {
    font-size: 1.1rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
  }

  .admin-company-badge {
    border: 1px solid var(--color-line);
    border-radius: 999px;
    color: var(--color-muted);
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.12rem 0.55rem;
  }

  .admin-email-link {
    color: #9df8ff;
    font-size: 0.92rem;
    margin-block-start: 0.25rem;
    display: inline-block;
  }

  .admin-email-link:hover,
  .admin-email-link:focus-visible {
    text-decoration: underline;
  }

  .admin-date-badge {
    border: 1px solid var(--color-line);
    border-radius: 10px;
    color: var(--color-muted);
    font-size: 0.75rem;
    padding: 0.25rem 0.5rem;
    white-space: nowrap;
  }

  .admin-inbox-meta {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3);
    background: rgba(255, 255, 255, 0.01);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    padding: var(--space-4);
  }

  .admin-meta-label {
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-block-end: 0.2rem;
  }

  .admin-meta-value {
    color: var(--color-text);
    font-size: 0.95rem;
    font-weight: 600;
  }

  .admin-message-box {
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.01);
    padding: var(--space-4);
    white-space: pre-wrap;
    color: #d9e2ec;
  }

  @media (min-inline-size: 48rem) {
    .admin-inbox-meta {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>