---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/admin.css';
---

<BaseLayout title="Esticode | Admin recenzii" robots="noindex,nofollow">

  <main class="admin-shell">
    <header class="admin-header">
      <p class="admin-kicker">Esticode</p>
      <h1>Admin recenzii</h1>
      <p>Schvalovanie recenzii pred publikovanim na webe.</p>
    </header>

    <section class="admin-login" id="admin-login">
      <h2>Prihlasenie</h2>
      <p>Zadaj admin heslo pre pristup k schvalovaniu recenzii.</p>
      <form id="admin-login-form" class="admin-form" aria-label="Admin login">
        <label for="admin-password">Heslo</label>
        <input id="admin-password" name="admin-password" type="password" autocomplete="current-password" required>
        <button type="submit" class="button button-primary">Prihlasit</button>
        <p id="admin-login-message" class="admin-message" aria-live="polite"></p>
      </form>
    </section>

    <section class="admin-panel" id="admin-panel" hidden>
      <div class="admin-toolbar">
        <button type="button" class="button button-outline" id="admin-logout">Odhlasit</button>
        <button type="button" class="button button-outline" id="admin-export">Export schvalenych</button>
        <a class="button button-outline" href="/">Spat na web</a>
      </div>

      <article class="admin-card">
        <h2>Cakajuce recenzie</h2>
        <p class="admin-hint">Recenzie su verejne az po schvaleni. Vzdy over klientsky kod projektu.</p>
        <div id="pending-list" class="admin-list" aria-live="polite"></div>
      </article>

      <article class="admin-card">
        <h2>Schvalene recenzie</h2>
        <div id="approved-list" class="admin-list" aria-live="polite"></div>
      </article>

      <article class="admin-card admin-note">
        <h2>Poznamka k bezpecnosti</h2>
        <p>Tento admin je idealny na rychle nasadenie statickej stranky, ale heslo aj data su lokalne v prehliadaci. Pre produkciu odporucam backend s overenim identity a uloziskom mimo localStorage.</p>
      </article>
    </section>
  </main>

  <script>
    import '../scripts/admin.js';
  </script>
</BaseLayout>
