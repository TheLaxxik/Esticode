---
export const prerender = false;

import fs from 'node:fs/promises';
import path from 'node:path';
import { fileURLToPath } from 'node:url';

const ADMIN_PASSWORD = import.meta.env.ADMIN_PASSWORD;
const cookies = Astro.cookies;
const isLoggedIn = cookies.get('admin_auth')?.value === ADMIN_PASSWORD;

const rootDir = path.resolve(path.dirname(fileURLToPath(import.meta.url)), '../../..');
const codesPath = path.join(rootDir, 'src', 'data', 'codes.json');

function generateCode(): string {
  const chars = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789';
  const rand = (n: number) => Array.from({ length: n }, () =>
    chars[Math.floor(Math.random() * chars.length)]).join('');
  return `ESTI-${rand(4)}-${rand(4)}`;
}

async function loadCodes() {
  let codesData: any = { codes: {}, stats: { totalGenerated: 0, totalUsed: 0 } };
  try {
    const raw = await fs.readFile(codesPath, 'utf-8');
    codesData = JSON.parse(raw);
  } catch {}
  return codesData;
}

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = form.get('action');

  if (action === 'login') {
    const password = form.get('password');
    if (password === ADMIN_PASSWORD) {
      cookies.set('admin_auth', ADMIN_PASSWORD, { path: '/admin', httpOnly: true });
      return Astro.redirect('/admin/codes');
    }
  }

  if (action === 'logout') {
    cookies.delete('admin_auth', { path: '/admin' });
    return Astro.redirect('/admin/codes');
  }

  if (action === 'generate') {
    if (!isLoggedIn) {
      return new Response(JSON.stringify({ success: false, error: 'Neautorizovaný.' }), {
        status: 401, headers: { 'Content-Type': 'application/json' }
      });
    }

    const client = form.get('client') as string;
    const type = form.get('type') as string;

    if (!client || !type) {
      return new Response(JSON.stringify({ success: false, error: 'Chýbajú údaje.' }), {
        status: 400, headers: { 'Content-Type': 'application/json' }
      });
    }

    const codesData = await loadCodes();

    let code = generateCode();
    while (codesData.codes[code]) code = generateCode();

    codesData.codes[code] = {
      used: false, type, client,
      createdAt: new Date().toISOString().split('T')[0]
    };
    codesData.stats.totalGenerated += 1;
    await fs.writeFile(codesPath, JSON.stringify(codesData, null, 2), 'utf-8');

    return new Response(JSON.stringify({ success: true, code }), {
      status: 200, headers: { 'Content-Type': 'application/json' }
    });
  }
}

const codesData = await loadCodes();
const codesList = Object.entries(codesData.codes) as [string, any][];
const free = codesData.stats.totalGenerated - codesData.stats.totalUsed;
---

<!DOCTYPE html>
<html lang="sk">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Esticode | Admin – Kódy</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: #141414;
      color: #e2e2e2;
      min-block-size: 100vh;
    }

    .login-wrap {
      max-inline-size: 320px;
      margin: 15vh auto;
      padding: 0 1rem;
    }
    .login-wrap h1 {
      font-size: 1.1rem;
      font-weight: 600;
      margin-block-end: 1.5rem;
      color: #fff;
    }
    .login-card {
      background: #1e1e1e;
      border: 1px solid #2a2a2a;
      border-radius: 8px;
      padding: 1.5rem;
    }

    .page {
      max-inline-size: 780px;
      margin: 0 auto;
      padding: 2rem 1.5rem;
    }

    .page-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-block-end: 2rem;
      padding-block-end: 1rem;
      border-block-end: 1px solid #2a2a2a;
    }
    .page-title {
      font-size: 1rem;
      font-weight: 600;
      color: #fff;
    }

    .stats {
      display: flex;
      gap: 0.75rem;
      margin-block-end: 2rem;
    }
    .stat {
      flex: 1;
      background: #1e1e1e;
      border: 1px solid #2a2a2a;
      border-radius: 6px;
      padding: 0.9rem 1rem;
      text-align: center;
    }
    .stat-number {
      font-size: 1.4rem;
      font-weight: 700;
      color: #fff;
    }
    .stat-label {
      font-size: 0.72rem;
      color: #666;
      margin-block-start: 0.2rem;
    }

    .card {
      background: #1e1e1e;
      border: 1px solid #2a2a2a;
      border-radius: 8px;
      padding: 1.25rem;
      margin-block-end: 1rem;
    }
    .card-title {
      font-size: 0.8rem;
      font-weight: 600;
      color: #888;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-block-end: 1rem;
    }

    .form-row {
      display: flex;
      gap: 0.75rem;
      align-items: flex-end;
    }
    .form-group {
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
      flex: 1;
    }
    label {
      font-size: 0.8rem;
      color: #888;
    }
    input, select {
      background: #141414;
      border: 1px solid #2a2a2a;
      border-radius: 6px;
      color: #e2e2e2;
      font-size: 0.875rem;
      padding: 0.5rem 0.75rem;
      inline-size: 100%;
      outline: none;
      transition: border-color 0.15s;
    }
    input:focus, select:focus { border-color: #555; }
    input::placeholder { color: #444; }

    .btn {
      padding: 0.5rem 1rem;
      border-radius: 6px;
      font-size: 0.85rem;
      font-weight: 500;
      cursor: pointer;
      border: none;
      white-space: nowrap;
    }
    .btn-primary { background: #2563eb; color: #fff; }
    .btn-primary:hover { background: #1d4ed8; }
    .btn-ghost {
      background: transparent;
      border: 1px solid #2a2a2a;
      color: #888;
      font-size: 0.8rem;
      padding: 0.4rem 0.8rem;
    }
    .btn-ghost:hover { border-color: #444; color: #ccc; }
    .btn-copy {
      background: #1e1e1e;
      border: 1px solid #2a2a2a;
      color: #888;
      font-size: 0.75rem;
      padding: 0.3rem 0.6rem;
      border-radius: 4px;
      cursor: pointer;
    }
    .btn-copy:hover { border-color: #444; color: #ccc; }

    #gen-result {
      margin-block-start: 0.75rem;
      font-size: 0.85rem;
      font-family: monospace;
      color: #4ade80;
      min-block-size: 1.2rem;
    }

    .codes-table {
      inline-size: 100%;
      border-collapse: collapse;
      font-size: 0.85rem;
    }
    .codes-table th {
      text-align: start;
      padding: 0.5rem 0.75rem;
      color: #555;
      font-size: 0.75rem;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      border-block-end: 1px solid #2a2a2a;
    }
    .codes-table td {
      padding: 0.65rem 0.75rem;
      border-block-end: 1px solid #1e1e1e;
      color: #ccc;
    }
    .codes-table tr:last-child td { border-block-end: none; }
    code {
      font-family: monospace;
      font-size: 0.85rem;
      color: #e2e2e2;
      letter-spacing: 0.03em;
    }

    .badge {
      display: inline-block;
      padding: 0.15rem 0.5rem;
      border-radius: 4px;
      font-size: 0.72rem;
      font-weight: 500;
    }
    .badge-free { background: #14532d33; color: #4ade80; border: 1px solid #14532d; }
    .badge-used { background: #450a0a33; color: #f87171; border: 1px solid #450a0a; }
    .badge-type { background: #1e3a5f33; color: #60a5fa; border: 1px solid #1e3a5f; }

    .empty { color: #444; font-size: 0.85rem; padding: 0.5rem 0; }
  </style>
</head>
<body>

{!isLoggedIn && (
  <div class="login-wrap">
    <h1>Admin prístup</h1>
    <div class="login-card">
      <form method="POST">
        <input type="hidden" name="action" value="login">
        <div class="form-group" style="margin-block-end:0.75rem;">
          <label>Heslo</label>
          <input type="password" name="password" autofocus required>
        </div>
        <button type="submit" class="btn btn-primary" style="inline-size:100%; margin-block-start:0.5rem;">Prihlásiť sa</button>
      </form>
    </div>
  </div>
)}

{isLoggedIn && (
  <div class="page">
    <div class="page-header">
      <span class="page-title">Správa klientských kódov</span>
      <form method="POST" style="margin:0;">
        <input type="hidden" name="action" value="logout">
        <button type="submit" class="btn btn-ghost">Odhlásiť</button>
      </form>
    </div>

    <div class="stats">
      <div class="stat">
        <div class="stat-number">{codesData.stats.totalGenerated}</div>
        <div class="stat-label">Vygenerovaných</div>
      </div>
      <div class="stat">
        <div class="stat-number">{codesData.stats.totalUsed}</div>
        <div class="stat-label">Použitých</div>
      </div>
      <div class="stat">
        <div class="stat-number">{free}</div>
        <div class="stat-label">Voľných</div>
      </div>
    </div>

    <div class="card">
      <p class="card-title">Nový kód</p>
      <div class="form-row">
        <div class="form-group">
          <label>Názov klienta</label>
          <input type="text" id="gen-client" placeholder="Napr. Kaviareň Noir">
        </div>
        <div class="form-group" style="max-inline-size:180px;">
          <label>Typ projektu</label>
          <select id="gen-type">
            <option value="landing-page">Landing page</option>
            <option value="firemny-web">Firemný web</option>
            <option value="redizajn">Redizajn</option>
          </select>
        </div>
        <button id="gen-btn" class="btn btn-primary">Generovať</button>
      </div>
      <p id="gen-result"></p>
    </div>

    <div class="card">
      <p class="card-title">Všetky kódy</p>
      {codesList.length === 0 && (
        <p class="empty">Zatiaľ žiadne kódy.</p>
      )}
      {codesList.length > 0 && (
        <table class="codes-table">
          <thead>
            <tr>
              <th>Kód</th>
              <th>Klient</th>
              <th>Typ</th>
              <th>Stav</th>
              <th>Dátum</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            {codesList.map(([code, entry]) => (
              <tr>
                <td><code>{code}</code></td>
                <td>{entry.client}</td>
                <td><span class="badge badge-type">{entry.type}</span></td>
                <td>{entry.used
                  ? <span class="badge badge-used">Použitý</span>
                  : <span class="badge badge-free">Voľný</span>}
                </td>
                <td style="color:#555;">{entry.createdAt}</td>
                <td>{!entry.used && <button class="btn-copy" data-code={code}>Kopírovať</button>}</td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </div>
  </div>
)}

<script>
  document.getElementById('gen-btn')?.addEventListener('click', async () => {
    const client = (document.getElementById('gen-client') as HTMLInputElement).value.trim();
    const type = (document.getElementById('gen-type') as HTMLSelectElement).value;
    const result = document.getElementById('gen-result');

    if (!client) {
      if (result) result.textContent = '⚠️ Zadaj názov klienta.';
      return;
    }

    if (result) result.textContent = 'Generujem...';

    const formData = new FormData();
    formData.append('action', 'generate');
    formData.append('client', client);
    formData.append('type', type);

    const res = await fetch('/admin/codes', {
      method: 'POST',
      body: formData
    });

    const data = await res.json();
    if (data.success) {
      if (result) result.textContent = `✅ ${data.code}`;
      setTimeout(() => location.reload(), 1500);
    } else {
      if (result) result.textContent = `❌ ${data.error}`;
    }
  });

  document.querySelectorAll('.btn-copy').forEach(btn => {
    btn.addEventListener('click', () => {
      const code = (btn as HTMLElement).dataset.code || '';
      navigator.clipboard.writeText(code);
      btn.textContent = '✓ Skopírované';
      setTimeout(() => btn.textContent = 'Kopírovať', 2000);
    });
  });
</script>

</body>
</html>