---
interface Props {
  title: string;
  description?: string;
  robots?: string;
  cssFile?: string;
  ogTitle?: string;
  ogDescription?: string;
}

const {
  title,
  description = 'Esticode z Košíc tvorí rýchle a čisté weby pre kaviarne a malé firmy.',
  robots = 'index,follow',
  cssFile = '/src/styles/global.css',
  ogTitle,
  ogDescription,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="sk">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content={description}>
  <meta name="robots" content={robots}>
  <meta name="theme-color" content="#111111">
  <meta name="color-scheme" content="dark">
  <meta property="og:locale" content="sk_SK">
  <meta property="og:type" content="website">
  <meta property="og:title" content={ogTitle ?? title}>
  <meta property="og:description" content={ogDescription ?? description}>
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/img/PFP_White.svg">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-RBBZVG7XQS" is:inline></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());

    gtag('config', 'G-RBBZVG7XQS');
  </script>
  <slot name="head" />
</head>
<body>
  <slot />
</body>
</html>
