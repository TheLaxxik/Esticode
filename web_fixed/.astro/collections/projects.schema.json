{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "slug": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "landing-page",
        "firemny-web",
        "redizajn"
      ]
    },
    "description": {
      "type": "string"
    },
    "image": {
      "type": "string"
    },
    "url": {
      "type": "string"
    },
    "demo": {
      "default": true,
      "type": "boolean"
    },
    "published": {
      "default": true,
      "type": "boolean"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "slug",
    "title",
    "type"
  ]
}